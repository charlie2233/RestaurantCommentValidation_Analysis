# QSR audit pipeline local settings
# Copy to `.env` and adjust local roots if needed.
# Do not commit real secrets here.

QSR_DATA_RAW=data/raw
QSR_DATA_BRONZE=data/bronze
QSR_DATA_SILVER=data/silver
QSR_DATA_GOLD=data/gold
QSR_DATA_REFERENCE=data/reference
QSR_GOLD_HISTORY_DIR=data/gold/history

QSR_REPORTS_DIR=reports
QSR_STRATEGY_DIR=strategy
QSR_ARTIFACTS_DIR=artifacts

QSR_LOG_LEVEL=INFO

# Keep real API keys in your shell environment, not in this file.
# OPENAI_API_KEY=***REDACTED***
# HF_TOKEN=***REDACTED***
