<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }}</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f4ef;
        --panel: #ffffff;
        --line: #ddd7cd;
        --text: #1f2937;
        --muted: #6b7280;
        --accent: #0f766e;
        --accent-soft: #def3ef;
        --warn: #9a6700;
        --warn-soft: #f8edda;
        --fail: #b42318;
        --fail-soft: #fee4e2;
        --good: #067647;
        --good-soft: #dcfae6;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(15, 118, 110, 0.10), transparent 26%),
          radial-gradient(circle at top right, rgba(154, 103, 0, 0.08), transparent 18%),
          var(--bg);
        color: var(--text);
      }
      .page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 32px 20px 48px;
      }
      .hero, .panel, .card {
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid var(--line);
        border-radius: 18px;
        box-shadow: 0 14px 32px rgba(15, 23, 42, 0.05);
      }
      .hero {
        padding: 24px;
        margin-bottom: 20px;
      }
      .eyebrow {
        margin: 0 0 8px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 12px;
        font-weight: 700;
      }
      h1, h2, h3 {
        margin: 0;
        line-height: 1.2;
      }
      h1 { font-size: clamp(2rem, 4vw, 2.8rem); }
      h2 { font-size: 1.25rem; margin: 26px 0 12px; }
      h3 { font-size: 1rem; margin: 0 0 10px; }
      .subtle {
        color: var(--muted);
        margin-top: 10px;
        max-width: 72ch;
        line-height: 1.55;
      }
      .grid {
        display: grid;
        gap: 14px;
      }
      .cards {
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      }
      .two-up {
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      }
      .card, .panel {
        padding: 16px;
      }
      .metric-label {
        color: var(--muted);
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .metric-value {
        margin-top: 6px;
        font-size: 2rem;
        font-weight: 760;
        letter-spacing: -0.03em;
      }
      .metric-note {
        color: var(--muted);
        font-size: 0.92rem;
        margin-top: 8px;
      }
      .badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
      }
      .good { background: var(--good-soft); color: var(--good); }
      .warn { background: var(--warn-soft); color: var(--warn); }
      .fail { background: var(--fail-soft); color: var(--fail); }
      .neutral { background: var(--accent-soft); color: var(--accent); }
      table {
        width: 100%;
        border-collapse: collapse;
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid var(--line);
        border-radius: 16px;
        overflow: hidden;
      }
      th, td {
        padding: 10px 12px;
        border-bottom: 1px solid var(--line);
        vertical-align: top;
        text-align: left;
      }
      tr:last-child td { border-bottom: none; }
      th {
        background: #faf8f4;
        color: var(--muted);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      ul {
        margin: 10px 0 0 18px;
        padding: 0;
      }
      li + li {
        margin-top: 6px;
      }
      .empty {
        color: var(--muted);
        font-style: italic;
      }
      .section {
        margin-top: 20px;
      }
      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }
    </style>
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <p class="eyebrow">{{ "Global Scorecard" if mode == "global" else "Brand Scorecard" }}</p>
        <h1>{{ title }}</h1>
        <p class="subtle">
          Generated at {{ generated_at }}. These reports are derived from local Gold-layer outputs and
          linked validation, reconciliation, and syntheticness artifacts.
        </p>
      </section>

      {% if mode == "global" %}
        {% set scorecard = global_scorecard %}
        <section class="grid cards">
          <div class="card">
            <div class="metric-label">Total brands</div>
            <div class="metric-value">{{ scorecard.total_brands }}</div>
          </div>
          <div class="card">
            <div class="metric-label">Clean brands</div>
            <div class="metric-value">{{ scorecard.validation_clean_brands }}</div>
          </div>
          <div class="card">
            <div class="metric-label">Warning brands</div>
            <div class="metric-value">{{ scorecard.validation_warning_brands }}</div>
          </div>
          <div class="card">
            <div class="metric-label">Failed brands</div>
            <div class="metric-value">{{ scorecard.validation_failed_brands }}</div>
          </div>
        </section>

        <section class="section grid two-up">
          <div class="panel">
            <h2>Validation Snapshot</h2>
            <div class="badge-row" style="margin-top: 12px;">
              <span class="badge {{ 'good' if scorecard.validation_passed else 'fail' }}">
                {{ 'PASS' if scorecard.validation_passed else 'FAIL' }}
              </span>
              <span class="badge neutral">Info {{ scorecard.validation_counts.get('info', 0) }}</span>
              <span class="badge warn">Warnings {{ scorecard.validation_counts.get('warning', 0) }}</span>
              <span class="badge fail">Errors {{ scorecard.validation_counts.get('error', 0) }}</span>
            </div>
          </div>
          <div class="panel">
            <h2>Syntheticness Overview</h2>
            <div class="metric-value">{{ scorecard.syntheticness_overview.get('total_signals', 0) }}</div>
            <div class="metric-note">Signals are weak-to-moderate triage inputs, not proof of fabrication.</div>
            {% if scorecard.syntheticness_overview.get('brands_requiring_review') is not none %}
              <div class="badge-row" style="margin-top: 12px;">
                <span class="badge warn">
                  Review required {{ scorecard.syntheticness_overview.get('brands_requiring_review', 0) }}
                </span>
                <span class="badge neutral">
                  Average score {{ scorecard.syntheticness_overview.get('average_brand_score', 0) }} / 100
                </span>
              </div>
            {% endif %}
            {% if scorecard.syntheticness_overview.get('by_strength') %}
              <ul>
                {% for strength, count in scorecard.syntheticness_overview.get('by_strength', {}).items() %}
                  <li><strong>{{ strength }}</strong>: {{ count }}</li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        </section>

        <section class="section">
          <h2>Warning Counts by Category</h2>
          {% if scorecard.warning_counts_by_category %}
            <table>
              <thead>
                <tr>
                  <th>Category</th>
                  <th>Count</th>
                </tr>
              </thead>
              <tbody>
                {% for category, count in scorecard.warning_counts_by_category.items() %}
                  <tr>
                    <td>{{ category }}</td>
                    <td>{{ count }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <p class="empty">No warning categories were recorded.</p>
          {% endif %}
        </section>

        <section class="section">
          <h2>Fields With Weakest Provenance</h2>
          {% if scorecard.weakest_provenance_fields %}
            <table>
              <thead>
                <tr>
                  <th>Field</th>
                  <th>Weak or Missing</th>
                  <th>Covered Brands</th>
                  <th>Average Confidence</th>
                </tr>
              </thead>
              <tbody>
                {% for row in scorecard.weakest_provenance_fields %}
                  <tr>
                    <td>{{ row.field_name }}</td>
                    <td>{{ row.weak_or_missing_count }}</td>
                    <td>{{ row.covered_brand_count }}</td>
                    <td>{{ row.average_reference_confidence }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <p class="empty">No provenance summary was available.</p>
          {% endif %}
        </section>

        <section class="section">
          <h2>Biggest Reconciliation Errors</h2>
          {% if scorecard.biggest_reconciliation_errors %}
            <table>
              <thead>
                <tr>
                  <th>Brand</th>
                  <th>Field</th>
                  <th>Absolute Error</th>
                  <th>Relative Error</th>
                  <th>Grade</th>
                </tr>
              </thead>
              <tbody>
                {% for row in scorecard.biggest_reconciliation_errors %}
                  <tr>
                    <td>{{ row.brand_name }}</td>
                    <td>{{ row.field_name }}</td>
                    <td>{{ row.absolute_error }}</td>
                    <td>{{ row.relative_error }}</td>
                    <td>{{ row.credibility_grade }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <p class="empty">No reconciliation comparisons were available.</p>
          {% endif %}
        </section>

        <section class="section grid two-up">
          <div class="panel">
            <h2>Artifact Warnings</h2>
            {% if warnings %}
              <ul>
                {% for warning in warnings %}
                  <li>{{ warning }}</li>
                {% endfor %}
              </ul>
            {% else %}
              <p class="empty">No artifact warnings were recorded.</p>
            {% endif %}
          </div>
          <div class="panel">
            <h2>Source Artifact Status</h2>
            {% if artifact_status %}
              <ul>
                {% for name, present in artifact_status.items() %}
                  <li><strong>{{ name }}</strong>: {{ 'present' if present else 'missing' }}</li>
                {% endfor %}
              </ul>
            {% else %}
              <p class="empty">No artifact status was recorded.</p>
            {% endif %}
          </div>
        </section>

        <section class="section">
          <h2>Brand-Level Overview</h2>
          {% if brand_scorecards %}
            <table>
              <thead>
                <tr>
                  <th>Brand</th>
                  <th>Validation</th>
                  <th>Credibility Grade</th>
                  <th>Open Issues</th>
                </tr>
              </thead>
              <tbody>
                {% for brand in brand_scorecards %}
                  <tr>
                    <td>{{ brand.canonical_brand_name }}</td>
                    <td>{{ brand.validation_status }}</td>
                    <td>{{ brand.overall_credibility_grade }}</td>
                    <td>{{ brand.open_issues | length }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <p class="empty">No brand scorecards were generated.</p>
          {% endif %}
        </section>
      {% else %}
        {% set brand = brand_scorecard %}
        <section class="grid cards">
          <div class="card">
            <div class="metric-label">Validation status</div>
            <div class="metric-value">{{ brand.validation_status }}</div>
          </div>
          <div class="card">
            <div class="metric-label">Credibility grade</div>
            <div class="metric-value">{{ brand.overall_credibility_grade }}</div>
          </div>
          <div class="card">
            <div class="metric-label">Open issues</div>
            <div class="metric-value">{{ brand.open_issues | length }}</div>
          </div>
        </section>

        <section class="section">
          <h2>Normalized Metrics</h2>
          {% if brand.normalized_metrics %}
            <table>
              <thead>
                <tr>
                  <th>Field</th>
                  <th>Value</th>
                </tr>
              </thead>
              <tbody>
                {% for key, value in brand.normalized_metrics.items() %}
                  <tr>
                    <td>{{ key }}</td>
                    <td>{{ value }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <p class="empty">No normalized metrics were available.</p>
          {% endif %}
        </section>

        <section class="section">
          <h2>Invariant Results</h2>
          {% if brand.invariant_results %}
            <table>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Status</th>
                  <th>Message</th>
                </tr>
              </thead>
              <tbody>
                {% for row in brand.invariant_results %}
                  <tr>
                    <td>{{ row.name }}</td>
                    <td>{{ row.status }}</td>
                    <td>{{ row.message }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <p class="empty">No invariant results were available.</p>
          {% endif %}
        </section>

        <section class="section grid two-up">
          <div class="panel">
            <h2>Provenance Grades</h2>
            {% if brand.provenance_grades %}
              <ul>
                {% for key, value in brand.provenance_grades.items() %}
                  <li><strong>{{ key }}</strong>: {{ value }}</li>
                {% endfor %}
              </ul>
            {% else %}
              <p class="empty">No provenance grades were available.</p>
            {% endif %}
          </div>
          <div class="panel">
            <h2>Open Issues</h2>
            {% if brand.open_issues %}
              <ul>
                {% for issue in brand.open_issues %}
                  <li>{{ issue }}</li>
                {% endfor %}
              </ul>
            {% else %}
              <p class="empty">No open issues were recorded.</p>
            {% endif %}
          </div>
        </section>

        <section class="section">
          <h2>Reconciliation Summary</h2>
          {% if brand.reconciliation_summary %}
            <table>
              <thead>
                <tr>
                  <th>Field</th>
                  <th>Reference Value</th>
                  <th>Absolute Error</th>
                  <th>Relative Error</th>
                  <th>Grade</th>
                  <th>Reference Source</th>
                </tr>
              </thead>
              <tbody>
                {% for row in brand.reconciliation_summary %}
                  <tr>
                    <td>{{ row.field_name }}</td>
                    <td>{{ row.reference_value }}</td>
                    <td>{{ row.absolute_error }}</td>
                    <td>{{ row.relative_error }}</td>
                    <td>{{ row.credibility_grade }}</td>
                    <td>{{ row.reference_source_name }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <p class="empty">No reconciliation comparisons were available.</p>
          {% endif %}
        </section>

        <section class="section">
          <h2>Syntheticness Signals</h2>
          <div class="grid two-up" style="margin-bottom: 14px;">
            <div class="panel">
              <h3>Syntheticness Summary</h3>
              <div class="badge-row" style="margin-top: 12px;">
                <span class="badge {{ 'warn' if brand.review_required else 'good' }}">
                  {{ 'Review required' if brand.review_required else 'No review required' }}
                </span>
                <span class="badge neutral">Score {{ brand.syntheticness_score }} / 100</span>
                <span class="badge neutral">Supporting signals {{ brand.supporting_signals | length }}</span>
              </div>
              <p class="metric-note">
                These scores are weak-to-moderate triage inputs, not proof of fabrication.
              </p>
              {% if brand.caveats %}
                <h3 style="margin-top: 16px;">Caveats</h3>
                <ul>
                  {% for caveat in brand.caveats %}
                    <li>{{ caveat }}</li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
            <div class="panel">
              <h3>Supporting Signals</h3>
              {% if brand.supporting_signals %}
                <table>
                  <thead>
                    <tr>
                      <th>Title</th>
                      <th>Strength</th>
                      <th>Field</th>
                      <th>Contribution</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in brand.supporting_signals %}
                      <tr>
                        <td>{{ row.title }}</td>
                        <td>{{ row.strength }}</td>
                        <td>{{ row.field_name }}</td>
                        <td>{{ row.score_contribution }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              {% else %}
                <p class="empty">No supporting signals were available.</p>
              {% endif %}
            </div>
          </div>
          {% if brand.syntheticness_signals %}
            <table>
              <thead>
                <tr>
                  <th>Title</th>
                  <th>Strength</th>
                  <th>Field</th>
                  <th>Explanation</th>
                </tr>
              </thead>
              <tbody>
                {% for row in brand.syntheticness_signals %}
                  <tr>
                    <td>{{ row.title }}</td>
                    <td>{{ row.strength }}</td>
                    <td>{{ row.field_name }}</td>
                    <td>{{ row.plain_english }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          {% else %}
            <p class="empty">No brand-specific syntheticness signals were recorded.</p>
          {% endif %}
        </section>
      {% endif %}
    </main>
  </body>
</html>
